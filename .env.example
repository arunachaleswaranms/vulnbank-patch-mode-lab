# VulnBank Workshop — Participant Setup
# ----------------------------------------
# 1. Get a free Groq API key at https://console.groq.com
# 2. Copy this file:  cp .env.example .env
# 3. Paste your key below and save

GROQ_API_KEY=your_groq_api_key_here

# Optional: override the default LLM model
# GROQ_MODEL=llama-3.3-70b-versatile

# ── Defensive "Patch Mode" (workshop hardening) ──────────────────────────
# off (default) = original vulnerable lab behavior, fully crackable.
# on            = server-side security controls enabled for all 5 levels.
# Live-switchable from the dashboard; this is only the boot-time default.
PATCH_MODE=off

# L5 (agent-to-agent) HMAC authentication — used only when Patch Mode is ON.
A2A_SHARED_SECRET=change_me_for_local_lab
A2A_MAX_SKEW_SECONDS=300
